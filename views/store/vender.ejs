<%- include('../partials/head') %>
  <%- include('../partials/background') %>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

      body {
        font-family: 'Outfit', 'Poppins', sans-serif !important;
        background-color: #fcfcfd;
        color: #1a1a1a;
        overflow-x: hidden;
      }

      /* Animations */
      @keyframes fadeUpIn {
        from {
          opacity: 0;
          transform: translateY(30px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes pulseGlow {
        0% {
          box-shadow: 0 8px 20px rgba(255, 75, 43, 0.3);
        }

        50% {
          box-shadow: 0 8px 30px rgba(255, 75, 43, 0.6);
        }

        100% {
          box-shadow: 0 8px 20px rgba(255, 75, 43, 0.3);
        }
      }

      @keyframes popIn {
        0% {
          opacity: 0;
          transform: scale(0.95);
        }

        100% {
          opacity: 1;
          transform: scale(1);
        }
      }

      /* Hero Banner */
      .hero-banner {
        width: 100%;
        height: 480px;
        position: relative;
        background: #000;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      }

      .hero-banner::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 60%);
        pointer-events: none;
      }

      .hero-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
      }

      @media (max-width: 768px) {
        .hero-banner {
          height: 300px;
        }
      }

      /* Vendor Map Section */
      .vendor-section {
        display: flex;
        align-items: center;
        gap: 40px;
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 24px;
        animation: fadeUpIn 0.8s ease forwards;
      }

      .vendor-heading {
        flex: 1;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        padding: 30px;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 1);
      }

      .vendor-heading h2 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 16px;
        background: linear-gradient(135deg, #FF416C, #FF4B2B);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .vendor-heading p {
        font-size: 1rem;
        color: #555;
        line-height: 1.6;
      }

      .vendor-map {
        flex: 1;
        height: 400px;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
        border: 6px solid #fff;
        position: relative;
        z-index: 1;
      }

      @media (max-width: 900px) {
        .vendor-section {
          flex-direction: column-reverse;
          gap: 20px;
          margin: 20px auto;
        }

        .vendor-map {
          width: 100%;
          height: 320px;
        }

        .vendor-heading {
          width: 100%;
          text-align: center;
        }
      }

      /* Cards Section */
      .mainDabba {
        max-width: 1280px;
        margin: 0 auto;
      }

      .cards-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 32px;
        margin-top: 40px;
        margin-bottom: 60px;
        padding-left: 5%;
      }

      .vendor-item {
        display: block;
        animation: fadeUpIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }

      /* Animation Stagger */
      .vendor-item:nth-child(1) {
        animation-delay: 0.1s;
      }

      .vendor-item:nth-child(2) {
        animation-delay: 0.15s;
      }

      .vendor-item:nth-child(3) {
        animation-delay: 0.2s;
      }

      .vendor-item:nth-child(4) {
        animation-delay: 0.25s;
      }

      .vendor-item:nth-child(n+5) {
        animation-delay: 0.3s;
      }

      .vendor-divider {
        display: none;
      }

      /* Card Styling */
      .card {
        background: #fff;
        border-radius: 28px;
        border: 1px solid rgba(0, 0, 0, 0.03);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        height: 100%;
        display: flex;
        flex-direction: column;
        width: 95%;
        position: relative;
        z-index: 1;
      }

      .card:hover {
        transform: translateY(-12px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
      }

      .card>a {
        display: flex;
        flex-direction: column;
        height: 100%;
        text-decoration: none;
        color: inherit;
      }

      .card img {
        width: 100%;
        height: 240px;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .card:hover img {
        transform: scale(1.05);
      }

      .card .content {
        padding: 24px;
        background: #fff;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        position: relative;
      }

      .content>div:first-child {
        margin-bottom: 12px;
      }

      .card h3 {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0;
        line-height: 1.3;
      }

      .rating {
        background: rgba(36, 150, 63, 0.1);
        color: #24963f;
        padding: 6px 12px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        margin-right: 18%;
        gap: 6px;
        white-space: nowrap;
        position: static !important;
        /* Overrides existing inline style */
      }

      .card p {
        font-size: 0.95rem;
        color: #666;
        margin: 8px 0;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px dashed rgba(0, 0, 0, 0.08);
        padding-bottom: 10px;
      }

      .card p:last-of-type {
        border-bottom: none;
      }

      .card p strong {
        color: #222;
        font-weight: 700;
        min-width: 130px;
      }

      /* Buttons */
      .reserve {
        margin-top: 24px;
        background: linear-gradient(135deg, #FF416C, #FF4B2B);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 16px;
        font-size: 1.05rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s;
        width: 100%;
        box-shadow: 0 8px 20px rgba(255, 75, 43, 0.3);
      }

      .reserve:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 25px rgba(255, 75, 43, 0.4);
        animation: pulseGlow 2s infinite;
      }

      .content>a:last-child {
        margin-top: auto;
      }

      /* Favorite Button */
      .fav-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 10;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: none;
        border-radius: 50%;
        padding: 10px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .fav-btn:hover {
        transform: scale(1.15);
        background: #fff;
      }

      .fav-btn button {
        outline: none;
        background: transparent;
        border: none;
        padding: 0;
        cursor: pointer;
      }

      .fav-btn img {
        width: 28px !important;
        height: 28px !important;
        transition: all 0.3s;
      }

      #favImg1 {
        filter: grayscale(100%);
        opacity: 0.6;
      }

      #favImg1:hover {
        filter: grayscale(0%);
        opacity: 1;
        transform: scale(1.1);
      }

      #favImg2 {
        filter: drop-shadow(0 0 5px rgba(255, 75, 43, 0.4));
      }

      #favImg2:hover {
        transform: scale(1.1);
      }

      /* Features Section */
      .features-section {
        padding: 80px 40px;
        background: #fff;
        border-radius: 40px;
        margin: 60px auto;
        max-width: 1200px;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.03);
      }

      .section-header h2 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #1a1a1a;
        text-align: center;
        margin-bottom: 20px;
      }

      .section-header p {
        text-align: center;
        font-size: 1.1rem;
        color: #666;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
        margin-top: 50px;
      }

      .feature-item {
        text-align: center;
        padding: 40px 24px;
        border-radius: 30px;
        background: transparent;
        transition: all 0.4s;
        border: 2px solid transparent;
      }

      .feature-item:hover {
        transform: translateY(-10px);
        background: #fff;
        border-color: rgba(255, 75, 43, 0.1);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
      }

      .feature-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #FF416C, #FF4B2B);
        color: white;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        margin: 0 auto 24px;
        transform: rotate(-5deg);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }

      .feature-item:hover .feature-icon {
        transform: rotate(0) scale(1.1);
        box-shadow: 0 15px 30px rgba(255, 75, 43, 0.3);
      }

      .feature-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #111;
        margin-bottom: 12px;
      }

      .feature-desc {
        color: #666;
        font-size: 1rem;
        line-height: 1.6;
      }

      /* Offers Section Modern */
      .offers-section-modern {
        margin: 80px auto;
        max-width: 1200px;
        padding: 0 20px;
      }

      .offers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 30px;
        margin-top: 50px;
      }

      .offer-card-modern {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        border-radius: 30px;
        padding: 40px 30px;
        position: relative;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.04);
        transition: all 0.4s;
        z-index: 1;
        overflow: hidden;
      }

      .offer-card-modern::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(255, 65, 108, 0.05), rgba(255, 75, 43, 0.05));
        z-index: -1;
        opacity: 0;
        transition: opacity 0.4s;
      }

      .offer-card-modern:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
        border-color: rgba(255, 75, 43, 0.2);
      }

      .offer-card-modern:hover::before {
        opacity: 1;
      }

      .offer-badge-modern {
        display: inline-block;
        background: linear-gradient(135deg, #1a1a1a, #333);
        color: white;
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 800;
        margin-bottom: 20px;
        letter-spacing: 1px;
        text-transform: uppercase;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
      }

      .offer-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 12px;
      }

      /* Thali Modal Refined */
      .thali-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(5px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }

      .thali-modal.show {
        display: flex;
      }

      .thali-modal-content {
        background: #fff;
        border-radius: 30px;
        padding: 40px 30px;
        width: 90%;
        max-width: 420px;
        text-align: center;
        position: relative;
        animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
      }

      @keyframes scaleIn {
        from {
          transform: scale(0.9);
          opacity: 0;
        }

        to {
          transform: scale(1);
          opacity: 1;
        }
      }

      .thali-image {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto 24px;
        border: 6px solid #f8f9fa;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
      }

      .thali-price {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a1a1a;
      }

      .thali-actions {
        display: flex;
        gap: 16px;
        margin-top: 24px;
      }

      .order-btn {
        flex: 1;
        padding: 16px;
        background: linear-gradient(135deg, #FF416C, #FF4B2B);
        color: white;
        border: none;
        border-radius: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
      }

      .order-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 75, 43, 0.3);
      }

      .cancel-btn {
        flex: 1;
        padding: 16px;
        background: #f1f2f6;
        border: none;
        border-radius: 16px;
        font-weight: 800;
        color: #555;
        cursor: pointer;
        transition: 0.3s;
      }

      .cancel-btn:hover {
        background: #e2e4eb;
      }

      .grayscale {
        filter: grayscale(100%);
        opacity: 0.7;
      }
    </style>

    <%- include('../partials/nav') %>


      <%- include('../partials/deliveringMsg') %>
        <!-- ✅ Slideshow Section -->
        <div class="hero-banner">
          <picture>
            <!-- Desktop & Tablet -->
            <!-- <source srcset="/s5.png" media="(min-width: 481px)"> -->

            <!-- Mobile -->
            <img src="/s5.png" alt="tiffin Banner">
          </picture>
        </div>
        <% if (user && user.userType==='guest' && user.welcomeOffer.amount> 0) { %>
          <div class="offer-banner"
            style="background:#FFEFD5; padding:8px; text-align:center; margin-bottom:10px; border-radius:6px;">
            <% if (!user.welcomeOffer.isUsed) { %>
              🎉 You have ₹<%= user.welcomeOffer.amount %> OFF on your monthly subscriptions!
                <% } else { %>
                  ✅ You’ve already used your ₹<%= user.welcomeOffer.amount %> welcome offer.
                    <% } %>
          </div>
          <% } %>


            <% if (user && user.userType==='vender' && vendorArea && vendorArea.coordinates) { %>

              <div class="vendor-section">
                <!-- 🗺️ Map -->
                <div class="vendor-map">
                  <div id="vendorMap"
                    style="height: 100%; width: 100%; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
                  </div>
                </div>

                <!-- 🧭 Heading -->
                <div class="vendor-heading">
                  <h2>👥 See all the customers in your service area range...</h2>
                  <p style="font-size:14px; color:#555; margin-top:5px;">
                    🟩 <b>Green:</b> Your current customers &nbsp;&nbsp;|&nbsp;&nbsp;
                    🟦 <b>Blue:</b> Potential customers in your area
                  </p>
                </div>
              </div>

              <!-- Hidden inputs -->
              <input type="hidden" id="vendorAreaData" value='<%- JSON.stringify(vendorArea) %>' />
              <input type="hidden" id="customersData" value='<%- JSON.stringify(customersInArea) %>' />
              <input type="hidden" id="bookedUsersData" value='<%- JSON.stringify(bookedCustomers || []) %>' />

              <!-- Leaflet CSS & JS -->
              <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
              <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

              <script>
                document.addEventListener("DOMContentLoaded", function () {
                  const vendorArea = JSON.parse(document.getElementById("vendorAreaData").value);
                  const customers = JSON.parse(document.getElementById("customersData").value || "[]");
                  const bookedCustomers = JSON.parse(document.getElementById("bookedUsersData").value || "[]");

                  if (!vendorArea || !vendorArea.coordinates) return;

                  const coords = vendorArea.coordinates[0];
                  const map = L.map("vendorMap", { zoomControl: true }).setView([coords[0][1], coords[0][0]], 13);

                  L.tileLayer("https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png", {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/">OpenStreetMap</a>',
                  }).addTo(map);

                  // Vendor service polygon
                  const polygonCoords = coords.map(([lng, lat]) => [lat, lng]);
                  const polygon = L.polygon(polygonCoords, {
                    color: "#FF7B00",
                    fillColor: "#FFB347",
                    fillOpacity: 0.3,
                    weight: 3
                  }).addTo(map);

                  map.fitBounds(polygon.getBounds());

                  // ✅ Show only "guest" users, not vendors
                  const guestUsers = customers.filter(c => c.userType === 'guest');

                  guestUsers.forEach(c => {
                    // check if user is among booked customers
                    const isBooked = bookedCustomers.some(b => b._id === c._id || b.id === c._id);

                    const markerColor = isBooked ? "#28a745" : "#007BFF"; // green or blue

                    L.circleMarker([c.lat, c.lng], {
                      radius: 6,
                      color: markerColor,
                      fillColor: markerColor,
                      fillOpacity: 0.9
                    })
                      .addTo(map)
                      .bindPopup(`
        <b>${c.name || "Customer"}</b><br>
        ${isBooked ? "✅ <b>Current Customer</b>" : "🟦 Potential Customer"}
      `);
                  });

                  // ✅ Fix map rendering if inside flex container
                  setTimeout(() => map.invalidateSize(), 300);
                });
              </script>
              <% } %>

                <h2 style="    margin-top: 40px;
    text-align: center;
    background: linear-gradient(135deg, #5e1d1d, #d42000);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: #1a1a1a;">
                  Discover Meals from Different Vendors!
                </h2>


                <% if (errorMessage) { %>
                  <div style="background:#f8d7da; color:#721c24; padding:10px; border-radius:6px; margin-bottom:15px;">
                    <%= errorMessage %>
                  </div>
                  <% } %>
                    <% if (birthdayMessage) { %>
                      <script>
                        document.addEventListener("DOMContentLoaded", function () {
                          Swal.fire({
                            title: '🎉 Happy Birthday!',
                            text: "<%= birthdayMessage %>",
                            icon: 'success',
                            confirmButtonText: 'Thanks!',
                            backdrop: `
          rgba(0,0,123,0.4)
          url("https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExMnV0b3AwcXJycWJwdzY1aDFpMHMzOWUyZWQ0dDNqejRmZTJkNXdlOSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/11sBLVxNs7v6WA/giphy.gif")
          left top
          no-repeat
        `,
                            showClass: {
                              popup: 'animate__animated animate__fadeInDown'
                            },
                            hideClass: {
                              popup: 'animate__animated animate__fadeOutUp'
                            }
                          });
                        });
                      </script>
                      <% } %>

                        <div class="mainDabba">

                          <div class="cards-container">
                            <% if (venders.length===0) { %>
                              <p style="text-align:center; margin-top: 40px; font-size: 18px; color: #888;">
                                No vendors found nearby
                              </p>
                              <% } else { %>
                                <% venders.forEach(vender=> { %>

                                  <% const totalReviews=vender.reviews ? vender.reviews.length : 0; const
                                    avgRating=totalReviews> 0
                                    ? (vender.reviews.reduce((sum, r) => sum + r.rating, 0) / totalReviews).toFixed(1)
                                    : "0.0";
                                    %>
                                    <div class="vendor-item">
                                      <div class="card">
                                        <a href="/user/vender-list/<%= vender._id %>">
                                          <% const bannerSrc=(vender.bannerImage && vender.bannerImage.trim() !=='' ) ?
                                            vender.bannerImage : '/tiffin.png' ; %>
                                            <img src="<%= bannerSrc %>" alt="Vendor Banner"
                                              class="<%= vender.vendorClass %> <%= vender.hasMenu ? '' : 'grayscale' %>"
                                              style="object-fit: cover; width: 100%; height: 180px; border-radius: 8px;">

                                            <div class="content">
                                              <div
                                                style="display:flex; justify-content:space-between; align-items:center;">
                                                <h3
                                                  style="text-overflow: ellipsis; white-space: nowrap; overflow: hidden; max-width: 70%;">
                                                  <%= vender.serviceName %>
                                                </h3>

                                                <style>
                                                  @media (max-width: 800px) {
                                                    .rating {
                                                      display: flex;
                                                      align-items: center;
                                                      gap: 4px;
                                                      margin-right: 18%;
                                                      position: absolute;
                                                      font-size: 14px;
                                                      left: 75%;
                                                      top: 80%;
                                                      color: #444;
                                                    }
                                                  }
                                                </style>
                                                <div class="rating">
                                                  <span style="color:#f5a623;">⭐</span>
                                                  <span>
                                                    <%= avgRating %>
                                                  </span>
                                                  <span style="color:#777;">(<%= totalReviews %>)</span>
                                                </div>
                                              </div>

                                              <p><strong>Price Per Meal:</strong> ₹<%= vender.pricePerDay || 0 %>
                                              </p>
                                              <p><strong>Price Per Month:</strong>
                                                <% if (typeof vender.pricePerMonthSingle !=='undefined' && typeof
                                                  vender.pricePerMonthBoth !=='undefined' ) { %>
                                                  ₹<%= vender.pricePerMonthSingle %> (Single meal) / ₹<%=
                                                      vender.pricePerMonthBoth %> (Both meals)
                                                      <% } else { %>
                                                        ₹<%= vender.pricePerMonth || 0 %>
                                                          <% } %>
                                              </p>

                                              <% if (showOptions) { %>
                                                <form action="/user/favourite_list" method="post" class="fav-btn">
                                                  <input type="hidden" name="venderId" value="<%= vender._id %>">
                                                  <% if (opacity[vender._id]==10) { %>
                                                    <button onclick="loading()" type="submit"
                                                      style="background: none; border: none;">
                                                      <img id="favImg2"
