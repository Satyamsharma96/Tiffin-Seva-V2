                          <script>
                            window.addEventListener('DOMContentLoaded', () => {
                              const birthdayMsg = document.getElementById('birthdayMessage').value;
                              const offerMsg = document.getElementById('welcomeOfferMessage').value;

                              if (birthdayMsg) {
                                // 🎂 Step 1: Show Birthday Alert
                                Swal.fire({
                                  title: '🎉 Happy Birthday!',
                                  text: birthdayMsg,
                                  icon: 'success',
                                  confirmButtonText: 'Thanks!',
                                  confirmButtonColor: '#FF7B00',
                                  backdrop: `
          rgba(0,0,123,0.4)
          url("https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExMnV0b3AwcXJycWJwdzY1aDFpMHMzOWUyZWQ0dDNqejRmZTJkNXdlOSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/11sBLVxNs7v6WA/giphy.gif")
          left top
          no-repeat
        `
                                }).then(() => {
                                  // 🎁 Step 2: Show Birthday Gift (₹100 OFF)
                                  if (offerMsg) {
                                    Swal.fire({
                                      title: '🎁 Birthday Gift!',
                                      text: offerMsg,
                                      icon: 'info',
                                      confirmButtonText: 'Awesome!',
                                      confirmButtonColor: '#28a745'
                                    });
                                  }
                                });
                              } else if (offerMsg) {
                                // 🎁 Only show welcome/birthday offer if no birthday alert
                                Swal.fire({
                                  title: '🎁 Welcome Offer!',
                                  text: offerMsg,
                                  icon: 'success',
                                  confirmButtonText: 'Okay',
                                  confirmButtonColor: '#FF7B00'
                                });
                              }
                            });
                          </script>

                          <!-- SweetAlert2 CDN -->
                          <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

                          <!-- Hidden fields for EJS data -->
                          <input type="hidden" id="guestAlert" value='<%= JSON.stringify(guestAlert || {}) %>' />
                          <input type="hidden" id="vendorAlert" value='<%= JSON.stringify(vendorAlert || {}) %>' />
                          <input type="hidden" id="userName" value="<%= user ? user.firstName : '' %>" />


                          <script>
                            document.addEventListener("DOMContentLoaded", async () => {
                              const guestAlert = JSON.parse(document.getElementById("guestAlert").value || "{}");
                              const vendorAlert = JSON.parse(document.getElementById("vendorAlert").value || "{}");
                              const userName = document.getElementById("userName").value;

                              // Wait for any birthday/welcome popup to close before showing new alerts
                              await new Promise(resolve => setTimeout(resolve, 500)); // small delay

                              // ✅ Handle Guest Alert (Always independent)
                              if (guestAlert && guestAlert.message) {
                                await Swal.fire({
                                  title: `Hey ${userName} 👋`,
                                  text: guestAlert.message,
                                  icon: 'info',
                                  showCancelButton: true,
                                  confirmButtonText: guestAlert.btnText || 'OK',
                                  cancelButtonText: 'Close',
                                  confirmButtonColor: '#3085d6',
                                  cancelButtonColor: '#aaa'
                                }).then((result) => {
                                  if (result.isConfirmed && guestAlert.redirect) {
                                    window.location.href = guestAlert.redirect;
                                  }
                                });
                              }

                              // ✅ Handle Vendor Alert (also independent)
                              if (vendorAlert && vendorAlert.message) {
                                await Swal.fire({
                                  title: 'Hello Chef 👨‍🍳',
                                  text: vendorAlert.message,
                                  icon: 'success',
                                  showCancelButton: true,
                                  confirmButtonText: vendorAlert.btnText || 'OK',
                                  cancelButtonText: 'Later',
                                  confirmButtonColor: '#28a745',
                                  cancelButtonColor: '#aaa'
                                }).then((result) => {
                                  if (result.isConfirmed && vendorAlert.redirect) {
                                    window.location.href = vendorAlert.redirect;
                                  }
                                });
                              }
                            });
                          </script>


                          <!-- ⭐ SPECIAL THALI MODAL -->
                          <div id="specialThaliModal" class="thali-modal">
                            <div class="thali-modal-content">

                              <span class="thali-close">&times;</span>

                              <h3 id="thaliVendor"></h3>

                              <img id="thaliImage" class="thali-image" />

                              <ul id="thaliItems"></ul>

                              <p class="thali-price">₹<span id="thaliPrice"></span></p>

                              <div class="thali-actions">
                                <button class="order-btn">Order</button>
                                <button class="cancel-btn">Cancel</button>
                              </div>

                            </div>
                          </div>
                          <script>
                            const modal = document.getElementById("specialThaliModal");
                            const itemsList = document.getElementById("thaliItems");
                            const orderBtn = document.querySelector(".order-btn");

                            let selectedVendorId = null;

                            document.querySelectorAll(".special-thali-card").forEach(card => {
                              card.addEventListener("click", () => {

                                selectedVendorId = card.dataset.vendorId;

                                document.getElementById("thaliVendor").innerText =
                                  "By " + card.dataset.vendor;

                                document.getElementById("thaliPrice").innerText =
                                  card.dataset.price;

                                document.getElementById("thaliImage").src =
                                  card.dataset.image;

                                // Fill items
                                itemsList.innerHTML = "";
                                card.dataset.items.split("||").forEach(item => {
                                  const li = document.createElement("li");
                                  li.innerText = item;
                                  itemsList.appendChild(li);
                                });

                                modal.classList.add("show");
                              });
                            });

                            // ✅ ORDER BUTTON → REDIRECT
                            orderBtn.addEventListener("click", () => {
                              if (!selectedVendorId) return;

                              window.location.href =
                                `/user/booking/${selectedVendorId}?type=special-thali`;
                            });

                            // Close modal
                            document.querySelector(".thali-close").onclick = () =>
                              modal.classList.remove("show");

                            document.querySelector(".cancel-btn").onclick = () =>
                              modal.classList.remove("show");
                          </script>



